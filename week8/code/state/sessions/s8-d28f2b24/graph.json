          "code": "def get_primes(n):\n    primes = []\n    num = 2\n    while len(primes) < n:\n        for i in range(2, int(num**0.5) + 1):\n            if num % i == 0:\n                break\n        else:\n            primes.append(num)\n        num += 1\n    return primes\n\nprint(sum(get_primes(10000)))",
